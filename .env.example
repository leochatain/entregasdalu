# entregasdalu — environment template. Copy to .env for local dev (it's gitignored).
# The backend reads this file from the repo root automatically (python-dotenv).
#
# Local dev needs NO secrets and NO Google: set DEBUG + DEV_LOGIN_ENABLED and use
# the POST /api/dev/login bypass. The values below are a ready-to-run dev config.

# --- Local dev (uncomment for `make dev` / runserver) ---------------------
DEBUG=True
DEV_LOGIN_ENABLED=True
DEV_LOGIN_EMAIL=leochatain@gmail.com
ALLOWED_EMAILS=leochatain@gmail.com

# Paths default to the repo-root photos/ and data/app.db, so these are optional locally.
# PHOTOS_ROOT=./photos
# DATABASE_PATH=./data/app.db

# --- Production (DEBUG must be False; DEV_LOGIN_ENABLED must be unset/False) ---
# Used by docker-compose (both services read this file). See DEPLOY.md for the runbook.
# DEBUG=False
# DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# ALLOWED_EMAILS=lu@example.com,leochatain@gmail.com
# DOMAIN=entregasdalu.example.com            # Caddy provisions TLS for this host
# DJANGO_ALLOWED_HOSTS=entregasdalu.example.com
# CSRF_TRUSTED_ORIGINS=https://entregasdalu.example.com
# Container paths (match the docker-compose bind-mounts):
# PHOTOS_ROOT=/srv/photos
# DATABASE_PATH=/data/app.db
# THUMBS_ROOT=/data/thumbs                   # downscaled-photo cache (rw, under ./data)
# Google OAuth (prod sign-in; not needed in dev):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
