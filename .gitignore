# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

# Django / app
backend/staticfiles/

# SQLite — the irreplaceable artifact lives here, but the .db itself is local state
data/*.db
data/*.db-wal
data/*.db-shm

# Downscaled photo derivatives — a regenerable cache (diary/images.py)
data/thumbs/

# Curated photos are personal content, not source — keep the tier folders
# (drop-points for curation) but never commit the images themselves.
photos/*/*
!photos/*/.gitkeep

# Playwright MCP scratch (screenshots, snapshots, console logs)
.playwright-mcp/

# Secrets / local config
.env
.env.*
!.env.example

# OS
.DS_Store
